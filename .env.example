# AI Memory - Environment Variables
# Copy this file to .env.local and fill in values as needed.

# ─── Google Search Console ───
# Get your verification code from: https://search.google.com/search-console
# Then add your domain and choose "HTML tag" verification method.
NEXT_PUBLIC_GSC_VERIFICATION=your_verification_code_here

# ─── Google Analytics ───
# Create a GA4 property at: https://analytics.google.com
# Use measurement ID (format: G-XXXXXXXXXX)
GA_MEASUREMENT_ID=

# ─── Stripe (for payments, when ready) ───
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─── PyPI (for MCP Server publishing) ───
PYPI_API_TOKEN=
